{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": false,

    /* 强制所有代码使用同一个 @mysten/sui 实例，避免 Transaction 类型双重实例问题 */
    "paths": {
      "@mysten/sui/*": ["./node_modules/@mysten/sui/*"],
      "@mysten/wallet-standard": ["./node_modules/@mysten/wallet-standard"],
      "@mysten/wallet-standard/*": ["./node_modules/@mysten/wallet-standard/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}